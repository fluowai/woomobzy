# Copy your real local .env to .env before running docker compose.
# This example documents the variables expected by the Docker stack.

NODE_ENV=production

# Frontend build-time values. In Docker local, same-origin means Caddy proxies /api.
VITE_API_URL=same-origin
VITE_WHATSAPP_API_URL=/api/whatsapp
VITE_WHATSAPP_WS_URL=/api/whatsapp/ws

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Postgres/Supabase direct DB for WhatsApp Go service.
DATABASE_URL=postgresql://user:password@host:5432/postgres?sslmode=require
SUPABASE_DB_URL=postgresql://user:password@host:5432/postgres?sslmode=require
PGSSLMODE=require

# Internal service URLs for Docker network.
WHATSAPP_API_URL=http://whatsapp-service:3100
WHATSMEOW_URL=http://whatsapp-service:3100
AGRO_INTEL_URL=http://agro-intelligence:8000
NODE_URL=http://api:3002

# CORS
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3006,http://localhost:3002
CORS_ORIGINS=http://localhost:8080,http://localhost:3006,http://localhost:3002

# Optional integrations
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
WHATSAPP_INTERNAL_TOKEN=change-me
WHATSAPP_AI_AUTOMATION=true

