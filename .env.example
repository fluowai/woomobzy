# =============================================================================
# IMOBZY CRM - Environment Variables Template
# Copy this file to .env and fill in the values
# NEVER commit .env with real credentials
# =============================================================================

# ─── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# ─── App URLs ────────────────────────────────────────────────────────────────
VITE_PANEL_URL=https://your-domain.com
PUBLIC_APP_URL=https://your-domain.com
VITE_PUBLIC_APP_URL=https://your-domain.com
VITE_API_URL=same-origin

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-domain.com
CORS_ORIGINS=https://your-domain.com

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development

# ─── AI Integration (Required for matchmaking) ──────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=

# ─── WhatsApp ────────────────────────────────────────────────────────────────
VITE_WHATSAPP_API_URL=/api/whatsapp
VITE_WHATSAPP_WS_URL=/api/whatsapp/ws
WHATSAPP_SERVICE_TOKEN=change-me-in-production
WHATSAPP_INTERNAL_TOKEN=change-me-in-production
WHATSAPP_WS_JWT_SECRET=change-me-in-production
WHATSAPP_PROVIDER=whatsmeow
WHATSMEOW_URL=http://127.0.0.1:3100
WHATSAPP_API_URL=http://127.0.0.1:3100
ARRAPHA_API_URL=http://127.0.0.1:3007
WAHA_API_URL=http://127.0.0.1:3007
ARRAPHA_API_KEY=local-arrapha-api-key
WAHA_API_KEY=local-arrapha-api-key

# ─── Media Storage (MinIO) ──────────────────────────────────────────────────
MEDIA_STORAGE_PROVIDER=minio
MINIO_ENDPOINT=https://your-minio-endpoint.com
MINIO_PUBLIC_URL=https://your-minio-endpoint.com
VITE_MINIO_PUBLIC_URL=https://your-minio-endpoint.com
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_REGION=us-east-1
MINIO_MEDIA_BUCKET=imobzycrm
MINIO_WHATSAPP_BUCKET=imobzywhatsapp

# ─── Orulo Integration ──────────────────────────────────────────────────────
ORULO_CLIENT_ID=your_orulo_client_id
ORULO_CLIENT_SECRET=your_orulo_client_secret

# ─── DirectAdmin API ────────────────────────────────────────────────────────
DIRECT_ADMIN_URL=https://your-panel:2222
DIRECT_ADMIN_USER=your_da_user
DIRECT_ADMIN_API_KEY=your_da_api_key
WHM_MAIN_DOMAIN=your-domain.com

# ─── PostgreSQL (Supabase Pooler) ───────────────────────────────────────────
DATABASE_URL="postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-1-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require&default_query_exec_mode=simple_protocol"
SUPABASE_DB_URL="postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-1-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require&default_query_exec_mode=simple_protocol"
PGSSLMODE=require

# ─── MapBiomas (Rural niche) ───────────────────────────────────────────────
MAPBIOMAS_EMAIL=your_mapbiomas_email
MAPBIOMAS_PASSWORD=your_mapbiomas_password
MAPBIOMAS_POINT_DELTA=0.01
