# ============================================
# ImobFluow - Production Environment Template
# ============================================
# IMPORTANTE: Preencha com as credenciais reais antes do deploy
# Copie para .env e remova este comentário

# ===================
# SUPABASE (OBRIGATÓRIO)
# ===================
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-publica-anonima-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-chave-secreta-de-servico
SUPABASE_JWT_SECRET=sua-jwt-secret-com-minimo-32-caracteres
EMAIL_ENCRYPTION_KEY=gere-uma-chave-hexadecimal-de-64-caracteres

# ===================
# MINIO / S3 (MIDIAS)
# ===================
MEDIA_STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://seu-minio:9000
MINIO_PUBLIC_URL=https://midias.seu-dominio.com
MINIO_ACCESS_KEY=sua-access-key
MINIO_SECRET_KEY=sua-secret-key
MINIO_REGION=us-east-1
MINIO_MEDIA_BUCKET=imobzy-media
MINIO_WHATSAPP_BUCKET=whatsapp-media
MINIO_DOCUMENTS_BUCKET=imobzy-documents
MINIO_EXPORTS_BUCKET=imobzy-exports
MINIO_BACKUPS_BUCKET=imobzy-backups

# ===================
# BACKEND SERVER
# ===================
PORT=3002
NODE_ENV=production
VITE_API_URL=same-origin
VITE_WHATSAPP_API_URL=/api/whatsapp
VITE_WHATSAPP_WS_URL=/api/whatsapp/ws
WHATSAPP_API_URL=http://whatsapp-service:3100
WHATSAPP_INTERNAL_TOKEN=troque-por-um-token-longo-e-aleatorio

# ===================
# DOMÍNIOS PERMITIDOS (CORS)
# ===================
ALLOWED_ORIGINS=https://app.imobfluow.com.br,https://imobfluow.com.br,https://www.imobfluow.com.br,https://okaimoveis.com.br,https://www.okaimoveis.com.br
CORS_ORIGINS=https://app.imobfluow.com.br,https://imobfluow.com.br,https://www.imobfluow.com.br,https://okaimoveis.com.br,https://www.okaimoveis.com.br

# ===================
# AI SERVICES (OPCIONAL)
# ===================
GEMINI_API_KEY=sua-api-key-do-gemini
GROQ_API_KEY=sua-api-key-do-groq
GROQ_MATCH_MODEL=llama-3.1-8b-instant

# ===================
# IMOBZY AI CORE LOCAL (AUTO-HOSPEDADO)
# ===================
AI_CORE_DISABLED=false
AI_CORE_OLLAMA_URL=http://ollama:11434
AI_CORE_LITELLM_URL=http://litellm:4000
AI_CORE_QDRANT_URL=http://qdrant:6333
AI_CORE_REDIS_URL=redis://redis:6379
AI_CORE_DEFAULT_CHAT_MODEL=qwen2.5:7b
AI_CORE_DEFAULT_EMBEDDING_MODEL=nomic-embed-text
AI_CORE_TIMEOUT_MS=120000
AI_CORE_ENFORCE_CREDITS=false
OLLAMA_PORT=11434
OLLAMA_CPUS=2.00
OLLAMA_MEM_LIMIT=6g
QDRANT_PORT=6333
LITELLM_PORT=4000
LITELLM_MASTER_KEY=troque-por-uma-chave-litellm-longa

# ===================
# ORULO (CATALOGO URBANO)
ORULO_CLIENT_ID=seu-client-id-da-orulo
ORULO_CLIENT_SECRET=seu-client-secret-da-orulo
ORULO_CREDENTIALS_ENCRYPTION_KEY=gere-uma-chave-forte-com-pelo-menos-32-caracteres
ORULO_WEBHOOK_SECRET=gere-um-segredo-exclusivo-para-webhooks

# VIVAREAL (PORTAL DE IMOVEIS)
VIVAREAL_API_KEY=sua-api-key-vivareal
VIVAREAL_PARTNER_ID=seu-partner-id-vivareal

# ZAP IMOVEIS (PORTAL DE IMOVEIS)
ZAP_API_KEY=sua-api-key-zap
ZAP_PARTNER_ID=seu-partner-id-zap

# ===================
# WHM/cPanel (OPCIONAL)
# ===================
WHM_HOST=seu-servidor-whm.com
WHM_USER=root
WHM_TOKEN=seu-token-whm
WHM_MAIN_DOMAIN=imobfluow.com.br
PUBLIC_APP_URL=https://imobfluow.com.br
VITE_PUBLIC_APP_URL=https://imobfluow.com.br
VITE_PANEL_URL=https://app.imobfluow.com.br
PLATFORM_PUBLIC_IP=207.58.153.219
VITE_PLATFORM_IP=207.58.153.219

# ===================
# TRAEFIK / SSL AUTOMATICO
# ===================
# O backend escreve configs dinamicas de dominio nesta pasta.
# No docker-compose.yml ela e montada em /traefik/dynamic.
TRAEFIK_DYNAMIC_DIR=/traefik/dynamic

# Email usado no resolver ACME do Traefik. Atualize tambem em traefik/traefik.yml
# antes do primeiro deploy.
LETSENCRYPT_EMAIL=admin@imobfluow.com.br

# ===================
# VERIFICATION TOKEN
# ===================
VERIFY_DOMAIN_TOKEN=token-aleatorio-para-verificacao

# ===================
# LOGGING
# ===================
LOG_LEVEL=info
WHATSAPP_SERVICE_TOKEN=replace-with-a-dedicated-proxy-service-token
WHATSAPP_INTERNAL_TOKEN=replace-with-a-dedicated-go-to-node-token
WHATSAPP_WS_JWT_SECRET=replace-with-a-dedicated-websocket-jwt-secret
