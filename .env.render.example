# Render Web Service: imobzy-api
# Copie estes nomes para Environment > Environment Variables no Render.

NODE_ENV=production
PORT=3002

# Supabase
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=COLE_A_ANON_KEY_PUBLICA
SUPABASE_SERVICE_ROLE_KEY=COLE_A_SERVICE_ROLE_KEY_SOMENTE_NO_BACKEND

# Dominios permitidos a chamar a API
# Inclua todos os dominios Cloudflare/Vercel que servem o frontend.
ALLOWED_ORIGINS=https://seudominio.com.br,https://www.seudominio.com.br,https://imobzy.consultio.com.br

# Servicos auxiliares
WHATSAPP_API_URL=https://sua-api-whatsapp.example.com
WHATSAPP_INTERNAL_TOKEN=troque-por-um-token-longo-e-aleatorio
# Opcional: use apenas Redis externo. Nao use redis://localhost:6379 no Render.
REDIS_URL=
START_RURAL_WORKER=false

# IA e integracoes opcionais
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
DIRECTADMIN_API_KEY=
