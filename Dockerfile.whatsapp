FROM golang:1.25-alpine AS builder

RUN apk add --no-cache gcc musl-dev sqlite-dev

WORKDIR /app

COPY whatsapp-service/go.mod whatsapp-service/go.sum ./
RUN go mod download

COPY whatsapp-service/ ./
RUN go mod tidy && CGO_ENABLED=1 GOOS=linux go build -o whatsapp-service ./cmd/server

FROM alpine:3.19

RUN apk add --no-cache ca-certificates curl sqlite-libs

WORKDIR /app

COPY --from=builder /app/whatsapp-service .

RUN mkdir -p .sessions

EXPOSE 3100

CMD ["./whatsapp-service"]
