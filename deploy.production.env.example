NODE_ENV=production

# Domain
# Example:
# APP_DOMAIN=imobzy.com.br
# APP_URL=https://imobzy.com.br
APP_DOMAIN=your-domain.com
APP_URL=https://your-domain.com

# CORS. Keep your domain here. Add extra domains separated by commas if needed.
ALLOWED_ORIGINS=https://your-domain.com
CORS_ORIGINS=https://your-domain.com

# Frontend build-time values
VITE_API_URL=same-origin
VITE_WHATSAPP_API_URL=/api/whatsapp
VITE_WHATSAPP_WS_URL=/api/whatsapp/ws
VITE_PANEL_URL=https://your-domain.com

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Postgres/Supabase direct DB for services
DATABASE_URL=postgresql://user:password@host:5432/postgres?sslmode=require
SUPABASE_DB_URL=postgresql://user:password@host:5432/postgres?sslmode=require
PGSSLMODE=require

# MinIO / S3 media storage
MEDIA_STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=https://media.your-domain.com
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_REGION=us-east-1
MINIO_MEDIA_BUCKET=imobzy-media
MINIO_WHATSAPP_BUCKET=whatsapp-media
MINIO_DOCUMENTS_BUCKET=imobzy-documents
MINIO_EXPORTS_BUCKET=imobzy-exports
MINIO_BACKUPS_BUCKET=imobzy-backups

# Internal Docker network URLs
WHATSAPP_API_URL=http://whatsapp-service:3100
WHATSMEOW_URL=http://whatsapp-service:3100
AGRO_INTEL_URL=http://agro-intelligence:8000
NODE_URL=http://api:3002

# Optional integrations
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Email
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# WhatsApp / automation
WHATSAPP_INTERNAL_TOKEN=change-me-to-a-long-random-token
WHATSAPP_AI_AUTOMATION=true
