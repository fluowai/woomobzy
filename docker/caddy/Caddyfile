:80 {
  encode gzip zstd

  @whatsapp_ws path /api/whatsapp/ws /api/whatsapp/ws/*
  handle @whatsapp_ws {
    rewrite * /ws
    reverse_proxy whatsapp-service:3100
  }

  handle /api/* {
    reverse_proxy api:3002
  }

  handle /health {
    reverse_proxy api:3002
  }

  handle {
    reverse_proxy frontend:80
  }
}
