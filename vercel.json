{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/whatsapp/(.*)",
      "destination": "https://woomobzy-production.up.railway.app/api/whatsapp/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://woomobzy-production.up.railway.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
